{
  "name": "securewatch-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "client/dashboard",
    "client/sandbox",
    "server/relay"
  ],
  "scripts": {
    "start": "npm run start:relay & npm run start:sandbox & npm run start:siem & npm run start:docker",
    "start:relay": "cd \"server/relay\" && node index.js",
    "start:sandbox": "cd \"client/sandbox\" && npm run dev",
    "start:siem": "cd \"client/dashboard\" && npm run dev",
    "start:docker": "docker-compose up -d",
    "stop": "killall node && docker-compose stop",
    "install:all": "npm install"
  },
  "dependencies": {}
}
