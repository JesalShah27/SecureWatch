# SecureWatch Environment Configuration
# Copy this file to .env and fill in your actual values.
# ⚠️  NEVER commit the .env file to git — it's in .gitignore!

# -------------------------------------
# Elasticsearch & Kibana
# -------------------------------------
ELASTIC_PASSWORD=change_me_strong_password
KIBANA_PASSWORD=change_me_strong_password

# -------------------------------------
# PostgreSQL
# -------------------------------------
POSTGRES_USER=siemuser
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=siemdb

# -------------------------------------
# Redis
# -------------------------------------
REDIS_PASSWORD=change_me_strong_password

# -------------------------------------
# FastAPI Backend
# -------------------------------------
JWT_SECRET=change_me_to_a_long_random_string_min_32_chars

# CORS: comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000

# -------------------------------------
# Network Config
# -------------------------------------
# Set to the IP where SecureWatch is running on your network
SIEM_HOST_IP=192.168.1.4
LOCAL_SUBNET=192.168.1.0/24

# -------------------------------------
# Threat Intelligence (Optional)
# Get free keys at: virustotal.com and abuseipdb.com
# -------------------------------------
VIRUSTOTAL_API_KEY=
ABUSEIPDB_API_KEY=

# -------------------------------------
# Notifications (Optional)
# -------------------------------------
SMTP_SERVER=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL_DEST=
SLACK_WEBHOOK_URL=
